{
  "name": "infopunks-pay-sh-radar",
  "version": "0.1.0",
  "private": true,
  "exports": {
    "./sdk": "./src/sdk.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "lint": "tsc --noEmit --pretty false",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/server.js",
    "start:render": "npm run start",
    "smoke:production": "tsx scripts/smoke-production.ts",
    "smoke:backend": "node scripts/smoke-backend.mjs",
    "launch:scaffold": "python3 .agents/skills/launch/scripts/scaffold_launch_packet.py --root .",
    "launch:data": "python3 .agents/skills/launch/scripts/fetch_radar_live_data.py --output-dir launch",
    "harness:machine-translation-general": "node scripts/run-alibaba-machine-translation-general-harness.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:production": "tsx scripts/verify-production.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-react": "latest",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
